{
    "compilerOptions": {
        "target": "es2022",
        "useDefineForClassFields": true,
        "lib": [
            "DOM",
            "ESNext"
        ],
        "types": ["node"],
        "allowJs": false,
        "skipLibCheck": true,
        "allowSyntheticDefaultImports": true,
        "strict": true,
        "forceConsistentCasingInFileNames": true,
        "module": "ESNext",
        "moduleResolution": "bundler",
        "resolveJsonModule": true,
        "isolatedModules": true,
        "noEmit": true,
        "jsx": "react-jsx"
    },
    "include": ["src", "common"],
    "references": [
        {
            "path": "./tsconfig.node.json"
        }
    ]
}
